# === Required ===
LARK_APP_ID=
LARK_APP_SECRET=

# === Optional — Filtering ===
# LARK_ALLOWED_USER_IDS=         # Sender open_id whitelist, comma-separated
# LARK_ALLOWED_CHAT_IDS=         # Chat ID whitelist, comma-separated
# LARK_TEXT_CHUNK_LIMIT=4000     # Max chars per text chunk
# LARK_ENABLED_SKILLS=           # lark-cli skill whitelist for start.sh

# === Optional — Memory ===
# MEMORY_PROVIDER=file           # Memory backend: file | openviking | mem0
# LARK_MIN_SEARCH_SCORE=0.3     # Minimum relevance score (vector backends only)
# LARK_MAX_SEARCH_RESULTS=2     # Max episodes per query
# LARK_INACTIVITY_HOURS=3       # Auto-flush trigger threshold

# === Optional — OpenViking ===
# OPENVIKING_URL=http://localhost:1933
# OPENVIKING_API_KEY=

# === Optional — mem0 ===
# MEM0_URL=
# MEM0_API_KEY=
